---
import MainLayout from "../../layouts/MainLayout.astro";

const articles = [
  {
    title: "Designing Through Change",
    href: "/thinking/designing-through-change",
    description:
      "The evolution of digital design—from pages to platforms to intelligent systems—and how it changes how we build products.",
  },
  {
    title: "Measuring What Matters",
    href: "/thinking/measuring-what-matters",
    description:
      "Why design must connect directly to business KPIs—and how to turn design decisions into measurable impact.",
  },
  {
    title: "Governed Product System",
    href: "/thinking/governed-product-system",
    description:
      "Why real product systems require governance, observability, and discipline—and how to design for evolution without drift.",
  },
];
---

<MainLayout
  title="Thinking | Jorge Obando"
  description="Thinking by Jorge Obando on systems design, enterprise product strategy, AI integration, governance, and measurable business impact."
>
  <section class="thinking-page">
    <section class="hero">
      <p class="eyebrow">Thinking</p>
      <h1>Perspectives on systems, product, and AI</h1>
      <p class="lead">
        Writing that explores how complex systems are designed, scaled, and governed—
        across enterprise platforms, AI, and product ecosystems.
      </p>

      <p class="hero-links">
        <a href="/case-studies">See related case studies</a>
        <a href="/narrative">See how I operate</a>
      </p>
    </section>

    <section class="articles" aria-label="Thinking articles">
      {articles.map((article) => (
        <article class="article-card">
          <a href={article.href}>
            <h2>{article.title}</h2>
            <p>{article.description}</p>
          </a>
        </article>
      ))}
    </section>
  </section>
</MainLayout>

<style>
  .thinking-page {
    padding: 2.5rem 0 5rem;
  }

  .hero {
    max-width: 800px;
    margin-bottom: 3rem;
  }

  .eyebrow {
    margin: 0 0 0.6rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #a33a3a;
  }

  .hero h1 {
    margin: 0;
    font-size: clamp(2.5rem, 4vw, 4.15rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .lead {
    margin-top: 1.2rem;
    font-size: 1.1rem;
    line-height: 1.85;
    color: #555;
    max-width: 760px;
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
    margin: 1.2rem 0 0;
  }

  .hero-links a {
    font-size: 0.95rem;
    font-weight: 600;
    color: #111;
    text-decoration: none;
  }

  .articles {
    display: grid;
    gap: 1.25rem;
  }

  .article-card {
    border: 1px solid var(--divider);
    border-radius: 16px;
    background: #fff;
    padding: 1.5rem;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .article-card a {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .article-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.06);
  }

  .article-card h2 {
    margin: 0 0 0.6rem;
    font-size: 1.25rem;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  .article-card p {
    margin: 0;
    color: #555;
    line-height: 1.7;
    max-width: 720px;
  }

  @media (max-width: 768px) {
    .thinking-page {
      padding: 1.5rem 0 4rem;
    }

    .lead {
      font-size: 1.02rem;
      line-height: 1.8;
    }

    .hero-links {
      flex-direction: column;
      gap: 0.35rem;
    }
  }
</style>