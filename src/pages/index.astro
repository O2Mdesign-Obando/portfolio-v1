---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Jorge Obando | Director of Product Design">
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Director of Product Design · Enterprise Platforms · AI Integration</p>
      <h1>I design and govern systems that scale.</h1>
      <p class="lead">
        Design leader operating at the intersection of strategy, systems, and execution—building
        enterprise platforms that deliver measurable business impact.
      </p>
      <p class="supporting">
        I lead design as a strategic function, not a service—aligning product, engineering, data,
        and executive vision to deliver scalable, AI-enhanced platforms. My work focuses on
        transforming complex business challenges into governed systems that drive adoption,
        efficiency, and long-term value.
      </p>

      <div class="hero-actions">
        <a class="button button-primary" href="/case-studies">View Case Studies</a>
        <a class="button button-secondary" href="/resume">Download Resume</a>
      </div>
    </div>

    <div class="hero-visual">
      <img src="/images/profile.jpg" alt="Jorge Obando portrait" class="hero-image" />
    </div>
  </section>

  <section class="proof-bar" aria-labelledby="enterprise-impact-title">
    <div class="section-heading">
      <p class="section-label" id="enterprise-impact-title">Enterprise Impact</p>
    </div>

    <div class="proof-grid">
      <article class="proof-item">
        <h2>$1.2B+</h2>
        <p>Ecosystem Value Influenced</p>
      </article>

      <article class="proof-item">
        <h2>50M+</h2>
        <p>Users Across Platforms</p>
      </article>

      <article class="proof-item">
        <h2>40%</h2>
        <p>Operational Cost Reduction</p>
      </article>

      <article class="proof-item">
        <h2>300%</h2>
        <p>User Adoption Growth</p>
      </article>
    </div>

    <p class="proof-note">
      Delivered through enterprise platforms, AI integration, and cross-functional leadership.
    </p>
  </section>

  <section class="positioning" aria-labelledby="positioning-title">
    <div class="section-heading">
      <p class="section-label">Positioning</p>
      <h2 id="positioning-title">I operate at the intersection of:</h2>
    </div>

    <div class="three-up-grid">
      <article class="card">
        <h3>Strategy</h3>
        <p>
          Aligning product direction with business goals, market forces, and executive vision.
        </p>
      </article>

      <article class="card">
        <h3>Systems</h3>
        <p>
          Designing scalable platforms, workflows, and governance models that compound over time.
        </p>
      </article>

      <article class="card">
        <h3>Execution</h3>
        <p>
          Translating strategy into shipped products through cross-functional leadership and
          delivery discipline.
        </p>
      </article>
    </div>
  </section>

  <section class="operating-model" aria-labelledby="operating-model-title">
    <div class="section-heading">
      <p class="section-label">Operating Model</p>
      <h2 id="operating-model-title">How I Operate</h2>
      <p class="section-intro">
        A structured approach to turning research, systems, and AI into measurable business
        outcomes.
      </p>
    </div>

    <div class="three-up-grid">
      <article class="card">
        <h3>Decision Clarity</h3>
        <p>
          Turning research and insight into clear, accountable product decisions that align teams
          and reduce ambiguity.
        </p>
      </article>

      <article class="card">
        <h3>Scalable Systems</h3>
        <p>
          Designing platforms, workflows, and design systems that scale across products, markets,
          and organizations.
        </p>
      </article>

      <article class="card">
        <h3>Responsible AI Governance</h3>
        <p>
          Integrating AI with human judgment, transparency, and accountability to ensure systems
          are effective, ethical, and measurable.
        </p>
      </article>
    </div>
  </section>

  <section class="featured-work" aria-labelledby="featured-work-title">
    <div class="section-heading">
      <p class="section-label">Selected Work</p>
      <h2 id="featured-work-title">Enterprise Transformations</h2>
      <p class="section-intro">
        Selected work demonstrating how strategy, systems, and AI translate into measurable
        business outcomes.
      </p>
    </div>

    <div class="feature-list">
      <article class="feature-card">
        <p class="feature-kicker">Featured Case Study</p>
        <h3>AI-Powered Life Sciences Platform</h3>
        <p>
          Enterprise-wide digital and AI experience strategy for clinical research.
        </p>
        <p class="feature-outcome">
          Aligned product, data, and research workflows to improve decision-making and accelerate
          trial execution.
        </p>
        <a href="/case-studies/ai-life-sciences-platform">View Case Study</a>
      </article>

      <article class="feature-card">
        <p class="feature-kicker">Featured Case Study</p>
        <h3>SMB Marketplace &amp; Fintech Ecosystem</h3>
        <p>
          Unified marketplace and fintech ecosystem for millions of SMBs across Latin America.
        </p>
        <p class="feature-outcome">
          Consolidated fragmented tools into a scalable platform, enabling new revenue streams and
          operational efficiency at regional scale.
        </p>
        <a href="/case-studies/smb-marketplace-fintech">View Case Study</a>
      </article>
    </div>

    <p class="section-link">
      <a href="/case-studies">View All Work</a>
    </p>
  </section>

  <section class="audience-paths" aria-labelledby="audience-paths-title">
    <div class="section-heading">
      <p class="section-label">Audience Paths</p>
      <h2 id="audience-paths-title">Explore by Role</h2>
      <p class="section-intro">
        Select your perspective to see the most relevant view of my work and experience.
      </p>
    </div>

    <div class="audience-grid">
      <article class="card">
        <h3>Hiring Managers</h3>
        <p>Execution, outcomes, and leadership at scale.</p>
      </article>

      <article class="card">
        <h3>Founders / Executives</h3>
        <p>Strategic alignment, platform thinking, and business impact.</p>
      </article>

      <article class="card">
        <h3>Product Leaders</h3>
        <p>Systems thinking, cross-functional collaboration, and delivery.</p>
      </article>

      <article class="card">
        <h3>Recruiters</h3>
        <p>Clear signal, structured experience, and fast evaluation.</p>
      </article>
    </div>
  </section>

  <section class="advisory" aria-labelledby="advisory-title">
    <div class="section-heading">
      <p class="section-label">Advisory</p>
      <h2 id="advisory-title">Design Leadership at Scale</h2>
      <p class="section-intro">
        Fractional and advisory design leadership to accelerate platform transformation, AI
        integration, and organizational scale.
      </p>
    </div>

    <div class="advisory-panel">
      <p class="advisory-copy">
        I partner with organizations to lead critical design initiatives without the overhead of
        full-time leadership—aligning strategy, systems, and execution to deliver measurable
        business outcomes.
      </p>

      <ul class="engagement-list">
        <li>Interim Design Leadership</li>
        <li>AI Transformation Strategy</li>
        <li>Design System Modernization</li>
        <li>Organizational Design &amp; Hiring</li>
      </ul>

      <div class="advisory-grid">
        <article>
          <h3>Strategic Leadership</h3>
          <p>C-suite alignment and cross-functional orchestration.</p>
        </article>

        <article>
          <h3>AI Integration</h3>
          <p>Ethical frameworks, predictive systems, and governance.</p>
        </article>

        <article>
          <h3>Business Impact</h3>
          <p>KPI-driven outcomes and measurable performance.</p>
        </article>

        <article>
          <h3>Team Building</h3>
          <p>Scaling global teams, culture, and capability.</p>
        </article>
      </div>

      <a class="button button-primary" href="/contact">Discuss an Engagement</a>
    </div>
  </section>

  <section class="credibility" aria-labelledby="credibility-title">
    <div class="section-heading">
      <p class="section-label">Credibility</p>
      <h2 id="credibility-title">Trusted by Enterprise Organizations</h2>
      <p class="section-intro">
        Experience across Fortune 500 companies and high-growth organizations.
      </p>
    </div>

    <div class="logo-cloud" aria-label="Past clients and employers">
      <span>SAAMA Technologies</span>
      <span>AB InBev</span>
      <span>American Express</span>
      <span>Medidata</span>
    </div>
  </section>

  <section class="cta-band" aria-labelledby="cta-band-title">
    <div class="cta-band-inner">
      <p class="section-label section-label-light">Next Step</p>
      <h2 id="cta-band-title">Ready to build systems that scale?</h2>
      <p>
        Let’s align strategy, systems, and execution to drive measurable impact.
      </p>

      <div class="hero-actions">
        <a class="button button-inverse" href="/contact">Start a Conversation</a>
        <a class="button button-ghost" href="/case-studies">View Case Studies</a>
      </div>
    </div>
  </section>

  <section class="thinking-layer" aria-labelledby="thinking-layer-title">
    <div class="section-heading">
      <p class="section-label">Perspective</p>
      <h2 id="thinking-layer-title">Why This Matters</h2>
    </div>

    <div class="three-up-grid">
      <article class="card">
        <h3>Outcomes-Driven Leadership</h3>
        <p>Design aligned with strategic business goals and measurable outcomes.</p>
      </article>

      <article class="card">
        <h3>Cross-Functional Orchestration</h3>
        <p>Aligning product, engineering, data, and leadership to accelerate impact.</p>
      </article>

      <article class="card">
        <h3>AI as a Strategic Tool</h3>
        <p>Applying AI to solve real problems with transparency and accountability.</p>
      </article>
    </div>
  </section>

  <style>
    :global(main) {
      max-width: 1120px;
      padding: 32px 24px 96px;
    }

    section {
      margin-top: 88px;
    }

    .hero {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
      gap: 48px;
      align-items: start;
      margin-top: 48px;
    }

    .eyebrow,
    .section-label {
      margin: 0 0 16px;
      font-size: 13px;
      line-height: 1.4;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #666666;
    }

    .section-label-light {
      color: rgba(255, 255, 255, 0.72);
    }

    .hero h1 {
      font-size: clamp(2.8rem, 6vw, 5rem);
      line-height: 1.02;
      letter-spacing: -0.04em;
      margin-bottom: 20px;
      max-width: 10ch;
    }

    .lead {
      font-size: 24px;
      line-height: 1.45;
      color: #1a1a1a;
      margin: 0 0 16px;
      max-width: 30ch;
    }

    .supporting,
    .section-intro,
    .advisory-copy,
    .cta-band p {
      font-size: 18px;
      line-height: 1.7;
      color: #444444;
      margin: 0;
      max-width: 62ch;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 28px;
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 0 18px;
      border-radius: 999px;
      border: 1px solid #111111;
      text-decoration: none;
      font-size: 15px;
      font-weight: 600;
      transition: opacity 0.2s ease;
    }

    .button:hover {
      opacity: 0.82;
    }

    .button-primary {
      background: #111111;
      color: #ffffff;
    }

    .button-secondary,
    .button-ghost {
      background: transparent;
      color: #111111;
    }

    .button-inverse {
      background: #ffffff;
      color: #111111;
      border-color: #ffffff;
    }

    .hero-visual {
      width: 100%;
      display: flex;
      justify-content: flex-end;
    }

    .hero-image {
      width: 100%;
      max-width: 420px;
      height: 440px;
      object-fit: cover;
      object-position: center top;
      border-radius: 28px;
      border: 1px solid #dddddd;
      display: block;
    }

    .section-heading {
      margin-bottom: 28px;
    }

    .section-heading h2 {
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.1;
      letter-spacing: -0.03em;
      margin-bottom: 12px;
    }

    .proof-bar {
      padding-top: 20px;
    }

    .proof-grid,
    .three-up-grid,
    .audience-grid,
    .advisory-grid {
      display: grid;
      gap: 20px;
    }

    .proof-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .proof-item {
      padding-top: 20px;
      border-top: 1px solid #dddddd;
    }

    .proof-item h2 {
      font-size: clamp(2rem, 4vw, 2.75rem);
      line-height: 1;
      margin-bottom: 10px;
    }

    .proof-item p,
    .proof-note,
    .feature-card p,
    .card p,
    .advisory-grid p,
    .logo-cloud span {
      font-size: 16px;
      line-height: 1.6;
      color: #555555;
      margin: 0;
    }

    .proof-note {
      margin-top: 24px;
      max-width: 60ch;
    }

    .three-up-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .audience-grid,
    .advisory-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .card,
    .feature-card,
    .advisory-panel {
      border: 1px solid #e5e5e5;
      border-radius: 24px;
      padding: 24px;
      background: #ffffff;
    }

    .card h3,
    .feature-card h3,
    .advisory-grid h3 {
      font-size: 22px;
      line-height: 1.2;
      margin: 0 0 10px;
    }

    .feature-list {
      display: grid;
      gap: 20px;
    }

    .feature-kicker {
      font-size: 12px;
      line-height: 1.4;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #666666;
      margin-bottom: 12px;
    }

    .feature-outcome {
      margin-top: 12px;
    }

    .feature-card a,
    .section-link a {
      display: inline-block;
      margin-top: 18px;
      font-size: 15px;
      font-weight: 600;
      color: #111111;
      text-decoration: none;
    }

    .section-link {
      margin-top: 24px;
    }

    .engagement-list {
      margin: 20px 0 28px;
      padding-left: 20px;
      color: #444444;
      font-size: 16px;
      line-height: 1.8;
    }

    .advisory-grid {
      margin-bottom: 28px;
    }

    .logo-cloud {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 16px;
      padding-top: 8px;
    }

    .logo-cloud span {
      display: block;
      border: 1px solid #e5e5e5;
      border-radius: 999px;
      padding: 12px 16px;
      text-align: center;
      color: #222222;
      background: #fafafa;
      font-size: 14px;
    }

    .cta-band {
      background: #111111;
      color: #ffffff;
      border-radius: 32px;
      padding: 48px 32px;
    }

    .cta-band-inner {
      max-width: 760px;
    }

    .cta-band h2 {
      color: #ffffff;
      font-size: clamp(2rem, 4vw, 3.25rem);
      line-height: 1.08;
      letter-spacing: -0.03em;
      margin: 0 0 12px;
    }

    .cta-band p {
      color: rgba(255, 255, 255, 0.82);
    }

    .cta-band .button-ghost {
      color: #ffffff;
      border-color: rgba(255, 255, 255, 0.32);
    }

    @media (max-width: 960px) {
      .hero,
      .proof-grid,
      .three-up-grid,
      .logo-cloud {
        grid-template-columns: 1fr 1fr;
      }

      .hero {
        align-items: stretch;
      }
    }

    @media (max-width: 720px) {
      :global(main) {
        padding: 24px 20px 80px;
      }

      section {
        margin-top: 72px;
      }

      .hero,
      .proof-grid,
      .three-up-grid,
      .audience-grid,
      .advisory-grid,
      .logo-cloud {
        grid-template-columns: 1fr;
      }

      .hero {
        gap: 28px;
      }

      .lead {
        font-size: 21px;
      }

      .supporting,
      .section-intro,
      .advisory-copy,
      .cta-band p {
        font-size: 17px;
      }

      .hero-image {
        max-width: 100%;
        height: 300px;
      }

      .cta-band {
        border-radius: 24px;
        padding: 36px 24px;
      }
    }
  </style>
</MainLayout>