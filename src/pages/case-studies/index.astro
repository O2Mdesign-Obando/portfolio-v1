---
import MainLayout from "../../layouts/MainLayout.astro";

const featured = [
  {
    title: "AI-Powered Life Sciences Platform",
    href: "/case-studies/ai-life-sciences-platform",
    description:
      "Enterprise AI platform transforming clinical trial workflows, reducing cycle time and enabling data-driven decision-making at scale.",
  },
  {
    title: "SMB Marketplace & Fintech Ecosystem",
    href: "/case-studies/smb-marketplace-fintech",
    description:
      "Unified marketplace and fintech ecosystem serving millions of SMBs, enabling new revenue streams and operational efficiency across LATAM.",
  },
];

const additional = [
  {
    title: "Global Servicing Platform",
    href: "/case-studies/global-servicing-platform",
    description:
      "Redesign of an enterprise servicing platform to improve usability, streamline workflows, and support global scalability.",
  },
];
---

<MainLayout title="Case Studies | Jorge Obando">
  <section class="case-page">

    <!-- HERO -->
    <section class="hero">
      <p class="eyebrow">Case Studies</p>
      <h1>Enterprise systems, platform design, and measurable outcomes.</h1>
      <p class="lead">
        A curated selection of work spanning AI-powered platforms, fintech ecosystems,
        and enterprise transformation—focused on turning complexity into scalable,
        outcome-driven systems.
      </p>
    </section>

    <!-- FEATURED -->
    <section class="content-section">
      <h2>Featured Work</h2>

      <div class="cards-grid two-up">
        {featured.map((item) => (
          <a href={item.href} class="case-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <span class="link">View Case Study →</span>
          </a>
        ))}
      </div>
    </section>

    <!-- ADDITIONAL -->
    <section class="content-section">
      <h2>Selected Work</h2>

      <div class="cards-grid one-up">
        {additional.map((item) => (
          <a href={item.href} class="case-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <span class="link">View Case Study →</span>
          </a>
        ))}
      </div>
    </section>

  </section>
</MainLayout>

<style>
  .case-page {
    padding: 2.5rem 0 5rem;
  }

  .hero {
    max-width: 760px;
    margin-bottom: 3.5rem;
  }

  .eyebrow {
    margin: 0 0 0.6rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #a33a3a;
  }

  .hero h1 {
    margin: 0;
    font-size: clamp(2.6rem, 4vw, 4.2rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .lead {
    margin-top: 1.2rem;
    font-size: 1.1rem;
    line-height: 1.85;
    color: #555;
  }

  .content-section {
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--divider);
  }

  .content-section h2 {
    margin: 0 0 1.5rem;
    font-size: clamp(1.8rem, 2.2vw, 2.4rem);
  }

  .cards-grid {
    display: grid;
    gap: 1rem;
  }

  .cards-grid.two-up {
    grid-template-columns: repeat(2, 1fr);
  }

  .cards-grid.one-up {
    grid-template-columns: 1fr;
  }

  .case-card {
    display: block;
    border: 1px solid var(--divider);
    border-radius: 16px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    background: #fff;
    transition: all 0.2s ease;
  }

  .case-card:hover {
    transform: translateY(-2px);
    border-color: #ccc;
  }

  .case-card h3 {
    margin: 0 0 0.6rem;
    font-size: 1.2rem;
  }

  .case-card p {
    margin: 0;
    color: #555;
    line-height: 1.7;
  }

  .link {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.9rem;
    color: #a33a3a;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .cards-grid.two-up {
      grid-template-columns: 1fr;
    }

    .case-page {
      padding: 1.5rem 0 4rem;
    }
  }
</style>