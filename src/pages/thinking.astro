---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Thinking — Jorge Obando">
  <h1>Thinking</h1>

  <p style="font-size: 22px; margin-top: 16px;">
    Writing on product design, systems thinking, platform strategy, and AI-native experiences.
  </p>

  <div style="margin-top: 32px; border-top: 1px solid var(--divider);"></div>

  <section style="margin-top: 48px;">

    <article style="margin-bottom: 48px;">
      <h2>
        <a href="#" style="text-decoration: none; color: inherit;">
          Designing for Complex Systems
        </a>
      </h2>
      <p>
        How product design evolves when moving from single products to interconnected systems.
      </p>
    </article>

    <article style="margin-bottom: 48px;">
      <h2>
        <a href="#" style="text-decoration: none; color: inherit;">
          From Features to Platforms
        </a>
      </h2>
      <p>
        Rethinking product strategy when building scalable platforms instead of isolated features.
      </p>
    </article>

    <article style="margin-bottom: 48px;">
      <h2>
        <a href="#" style="text-decoration: none; color: inherit;">
          Designing AI-Native Experiences
        </a>
      </h2>
      <p>
        Moving beyond interfaces to systems that learn, adapt, and guide user behavior.
      </p>
    </article>

  </section>
</MainLayout>