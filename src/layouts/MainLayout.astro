---
import Header from "../components/Header.astro";

const { title = "Jorge Obando" } = Astro.props;
---

<html lang="en">
  <head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{title}</title>

  <meta name="description" content="Jorge Obando — Product Design Leader specializing in intelligent systems, platform strategy, and AI-native experiences." />

  <meta property="og:title" content={title} />
  <meta property="og:description" content="Product Design Leader focused on systems, platforms, and AI-native experiences." />
  <meta property="og:type" content="website" />

  <meta name="twitter:card" content="summary_large_image" />
  </head>

  <body>
    <main>
      <Header />
      <slot />
    </main>
  </body>
</html>