---
import Header from "../components/Header.astro";

const { title = "Jorge Obando" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>

    <meta name="description" content="Jorge Obando — Product Design Leader specializing in intelligent systems, platform strategy, and AI-native experiences." />

    <meta property="og:title" content={title} />
    <meta property="og:description" content="Product Design Leader focused on systems, platforms, and AI-native experiences." />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />

    <style>
      :root {
        --text-primary: #111111;
        --text-secondary: #555555;
        --background: #ffffff;
        --divider: #e5e5e5;
      }

      body {
        margin: 0;
        font-family: Inter, system-ui, sans-serif;
        background: var(--background);
        color: var(--text-primary);
      }

      main {
        max-width: 900px;
        margin: 0 auto;
        padding: 32px 24px 80px;
      }

      h1 {
        font-size: 48px;
        line-height: 1.2;
        margin: 0 0 24px;
      }

      h2 {
        margin: 0 0 12px;
      }

      p {
        font-size: 20px;
        line-height: 1.6;
        color: var(--text-secondary);
      }
    </style>
  </head>

  <body>
    <main>
      <Header />
      <slot />
    </main>
  </body>
</html>